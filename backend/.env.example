# ===========================================
# Sleep Relief Navigator - Backend Environment
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ===========================================
# MONGODB ATLAS
# ===========================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sleeprelief?retryWrites=true&w=majority

# ===========================================
# AUTHENTICATION (REQUIRED - USE STRONG SECRETS)
# ===========================================
# JWT Secret for access tokens (minimum 256-bit)
JWT_SECRET=your-super-secret-jwt-access-token-secret-min-256-bits-here

# Access token expiry (default: 15m)
JWT_ACCESS_EXPIRY=15m

# Refresh token secret (minimum 256-bit)
JWT_REFRESH_SECRET=your-super-secret-refresh-token-secret-min-256-bits-here

# Refresh token expiry (default: 7d)
JWT_REFRESH_EXPIRY=7d

# ===========================================
# STRIPE PAYMENTS
# ===========================================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Price IDs from Stripe Dashboard
STRIPE_PRICE_ONE_TIME=price_your_7night_reset_price_id
STRIPE_PRICE_SUBSCRIPTION=price_your_monthly_subscription_price_id

# ===========================================
# EMAIL (RESEND)
# ===========================================
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Email sender address
EMAIL_FROM=noreply@sleepreliefnavigator.com
EMAIL_FROM_NAME=Sleep Relief Navigator

# ===========================================
# UPSTASH REDIS (OPTIONAL - FOR RATE LIMITING)
# ===========================================
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ===========================================
# SENTRY ERROR TRACKING (OPTIONAL)
# ===========================================
# Get from https://sentry.io/settings
SENTRY_DSN=https://xxx@sentry.io/xxxxx

# ===========================================
# APPLICATION URLS
# ===========================================
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ===========================================
# RATE LIMITING
# ===========================================
# Enable Redis-based rate limiting (set to 'true' if Upstash configured)
USE_REDIS_RATE_LIMIT=false

# ===========================================
# LOGGING
# ===========================================
# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ===========================================
# SECURITY
# ===========================================
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Enable request logging
ENABLE_REQUEST_LOGGING=true