{
  "name": "sleep-relief-navigator-backend",
  "version": "1.0.0",
  "description": "Backend API for Sleep Relief Navigator",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "seed": "node src/scripts/seed.js",
    "seed:interventions": "node src/scripts/seedInterventions.js",
    "seed:evidence": "node src/scripts/seedEvidence.js",
    "seed:profiles": "node src/scripts/seedProfiles.js",
    "seed:rules": "node src/scripts/seedRules.js",
    "seed:pricing": "node src/scripts/seedPricing.js",
    "seed:all": "npm run seed:interventions && npm run seed:evidence && npm run seed:profiles && npm run seed:rules && npm run seed:pricing",
    "db:indexes": "node src/scripts/createIndexes.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "sleep",
    "health",
    "wellness",
    "api",
    "express",
    "mongodb"
  ],
  "author": "Sleep Relief Navigator",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^7.99.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "resend": "^2.0.0",
    "stripe": "^14.10.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}