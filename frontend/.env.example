# ===========================================
# Sleep Relief Navigator - Frontend Environment
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# API CONFIGURATION
# ===========================================
VITE_API_URL=http://localhost:5000/api/v1
VITE_APP_URL=http://localhost:5173

# ===========================================
# STRIPE
# ===========================================
# Get from https://dashboard.stripe.com/apikeys (use pk_test for development)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# ===========================================
# ANALYTICS (POSTHOG - OPTIONAL)
# ===========================================
# Get from https://app.posthog.com/settings/project
VITE_POSTHOG_KEY=phc_your_posthog_key
VITE_POSTHOG_HOST=https://app.posthog.com

# ===========================================
# SENTRY ERROR TRACKING (OPTIONAL)
# ===========================================
# Get from https://sentry.io/settings
VITE_SENTRY_DSN=https://xxx@sentry.io/xxxxx

# ===========================================
# FEATURE FLAGS (OPTIONAL)
# ===========================================
# Enable experimental features
VITE_ENABLE_EXPERIMENTAL_FEATURES=false